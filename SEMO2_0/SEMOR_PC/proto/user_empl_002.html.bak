<!DOCTYPE html>
<html lang="ko" xml:lang="ko">
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge, chrome=1">
<title>세모리포트</title>
<link rel="stylesheet" href="../css/reset_taxp.css">
<link rel="stylesheet" href="../css/app_header.css"><!-- [D] 세무대리인용 header -->
<link rel="stylesheet" href="../css/content_taxp.css"><!-- [D] 세무대리인용 -->

<!-- custom scrollbar plugin css -->
<link rel="stylesheet" href="../css/jquery.mCustomScrollbar.css">
<script src="../js/lib/jquery/jquery-1.12.4.min.js"></script>
<script src="../js/lib/jquery/jquery-ui-1.10.4.min.js"></script>
<!-- custom scrollbar plugin -->
<script src="../js/design/jquery.mCustomScrollbar.concat.min.js"></script>
<script src="../js/design/jquery.placeholder.min.js"></script>
<script src="../js/lib/plugin/smart.popup.js"></script>
<script src="../js/comm/common.js"></script>
<script>
$(function(){
  // Invoke the plugin
  $('input, textarea').placeholder({customClass:'my-placeholder'});
});
</script>

</head>


<body>

<div class="pop_wrap" style="width:650px;">

	<!-- 팝업 헤더 -->
	<div class="pop_header">
		<h1>직원상세 조회</h1>
		<a href="#none" onClick="self.close()" class="btn_popclose"><img src="../img/txof/btn/btn_popclose.gif" alt="팝업닫기"></a>
	</div>
	<!-- //팝업 헤더 -->

	<div class="mCustomScrollbar" style="max-height:600px;overflow-y:auto;">
	<!-- 팝업 컨텐츠 -->
	<div class="pop_container">

		<div class="title_wrap h1type">
			<div class="left"><h1> 기타소득자</h1></div>
			<div class="right"></div>
		</div>

		<div class="title_wrap">
			<div class="left">
				<div class="title">
					<h2 class="tx_title">기본정보</h2>
				</div>
			</div>
		</div>

		<div class="tbl_layout tbl_input_set mgb20">
			<table>
				<colgroup><col style="width:150px;"><col></colgroup>
				<tbody>
					<tr>
						<th scope="row"><div>성명 </div></th>
						<td>
							<div class="ipt">홍길동 / W202110101001</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>내/외국인 </div></th>
						<td>
							<div class="ipt">내국인</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>입사일자 </div></th>
						<td>
							<div class="ipt">2021-07-01</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>휴대폰번호 </div></th>
						<td>
							<div class="ipt">010-1111-2345</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>이메일 </div></th>
						<td>
							<div class="ipt">aaaa123@gmail.com</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>급여계좌</div></th>
						<td>
							<div class="ipt posiw">기업은행 / 101-256669-01-001 (예금주 : 홍길동)
							</div>
						</td>
					</tr>
				</tbody>
			</table>
		</div>

		<div class="title_wrap">
			<div class="left">
				<div class="title">
					<h2 class="tx_title">급여정보</h2>
				</div>
			</div>
		</div>

		<div class="tbl_layout tbl_input_set mgb20">
			<table>
				<colgroup><col style="width:150px;"><col></colgroup>
				<tbody>
					<tr>
						<th scope="row"><div>급여지급일</div></th>
						<td>
							<div class="ipt">25일</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>월급여</div></th>
						<td>
							<div class="ipt">1,000,000 원</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>식대</div></th>
						<td>
							<div class="ipt">적용/비적용</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>자가운전</div></th>
						<td>
							<div class="ipt">적용/비적용</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>육아수당</div></th>
						<td>
							<div class="ipt">적용/비적용</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>피부양자</div></th>
						<td>
							<div class="ipt">1명</div>
						</td>
					</tr>
					<tr>
						<th scope="row"><div>메모</div></th>
						<td>
							<div class="ipt">메모</div>
						</td>
					</tr>
				</tbody>
			</table>
		</div>

		<div class="title_wrap">
			<div class="left">
				<div class="title">
					<h2 class="tx_title">증빙서류</h2>
				</div>
			</div>
		</div>

		<div class="pop_intimg">
			<!-- 이미지 등록 후 -->
			<div class="img_intbx2 mgt5" style="border-bottom:0;">
				<div class="img_logo on">
					<div class="cell"><img src="../img/sample.gif" alt=""></div><div class="edit"><a class="imgdel"><span class="blind">이미지<br>삭제</span></a></div>
					<div class="textbox">
						<a href="#none" class="tx_ellipsis_max" style="display:block;">신분증</a>
						<div class="combo_postbx" style="width:137px;display:none;">
							<div class="combo_post_bg">
								<input type="text" style="width:100%;" placeholder="문서이름 입력" value="">
								<div class="btn" style="top:0;right:0;">
									<a class="del"><span class="blind">삭제</span></a>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="img_logo on">
					<div class="cell"><img src="../img/txof/bg/bg_data_type1.png" alt=""></div><div class="edit"><a class="imgdel"><span class="blind">이미지<br>삭제</span></a></div>
					<div class="textbox">
						<a href="#none" class="tx_ellipsis_max" style="display:block;">통장사본</a>
						<div class="combo_postbx" style="width:137px;display:none;">
							<div class="combo_post_bg">
								<input type="text" style="width:100%;" placeholder="문서이름 입력" value="">
								<div class="btn" style="top:0;right:0;">
									<a class="del"><span class="blind">삭제</span></a>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="img_logo on">
					<div class="cell"><img src="../img/txof/bg/bg_data_type2.png" alt=""></div><div class="edit"><a class="imgdel"><span class="blind">이미지<br>삭제</span></a></div>
					<div class="textbox">
						<a href="#none" class="tx_ellipsis_max" style="display:block;">근로계약서</a>
						<div class="combo_postbx" style="width:137px;display:none;">
							<div class="combo_post_bg">
								<input type="text" style="width:100%;" placeholder="문서이름 입력" value="">
								<div class="btn" style="top:0;right:0;">
									<a class="del"><span class="blind">삭제</span></a>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="img_logo on">
					<div class="cell"><img src="../img/txof/img_sign.gif" alt=""></div><div class="edit"><a class="imgdel"><span class="blind">이미지<br>삭제</span></a></div>
					<div class="textbox">
						<a href="#none" class="tx_ellipsis_max" style="display:block;">주민등록등본</a>
						<div class="combo_postbx" style="width:137px;display:none;">
							<div class="combo_post_bg">
								<input type="text" style="width:100%;" placeholder="문서이름 입력" value="">
								<div class="btn" style="top:0;right:0;">
									<a class="del"><span class="blind">삭제</span></a>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="img_logo on">
					<div class="cell"><img src="../img/txof/ico/img_file_pdf.png" alt=""></div><div class="edit"><a class="imgdel"><span class="blind">이미지<br>삭제</span></a></div>
					<div class="textbox">
						<a href="#none" class="tx_ellipsis_max" style="display:block;">자동차등록증</a>
						<div class="combo_postbx" style="width:137px;display:none;">
							<div class="combo_post_bg">
								<input type="text" style="width:100%;" placeholder="문서이름 입력" value="">
								<div class="btn" style="top:0;right:0;">
									<a class="del"><span class="blind">삭제</span></a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<!-- //이미지 등록 후 -->
		</div>

			    <!-- 하단버튼 -->
	    <div class="tac">
	      <a href="#none"  onClick="close_smartPop();" class="btn_style1"><span>닫기</span></a>
	    </div>
	    <!-- //하단버튼 -->
	</div>
	<!-- //팝업 컨텐츠 -->
	</div><!-- //mCustomScrollbar -->
</div>

</body>
</html>
